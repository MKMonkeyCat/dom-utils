{
  "name": "@mkmonkeycat/dom-utils",
  "version": "0.1.0",
  "description": "A TypeScript utility library for DOM manipulation and common web development tasks.",
  "homepage": "https://github.com/MKMonkeyCat/dom-utils#readme",
  "type": "module",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./dom": {
      "types": "./dist/dom/index.d.ts",
      "import": "./dist/dom/index.js",
      "require": "./dist/dom/index.cjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js",
      "require": "./dist/utils/index.cjs"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MKMonkeyCat/dom-utils.git"
  },
  "bugs": {
    "url": "https://github.com/MKMonkeyCat/dom-utils/issues"
  },
  "author": "MKMonkeyCat <a102009102009@gmail.com>",
  "license": "MIT",
  "keywords": [
    "typescript",
    "dom",
    "utilities",
    "utils",
    "library",
    "web",
    "frontend"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "prettier --log-level warn --write \"./**/*.{ts,tsx,css,md,json}\" && eslint ./src --ext .ts,.tsx --quiet --fix"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "happy-dom": "^20.8.3",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  }
}
