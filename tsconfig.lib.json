{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "ES2019",

    "lib": ["DOM", "ES2019"],

    "moduleResolution": "NodeNext",

    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "lib",

    "strict": true,
    "skipLibCheck": true,
    "strictPropertyInitialization": false,

    "esModuleInterop": true
  },
  "include": ["src/**/*"]
}
